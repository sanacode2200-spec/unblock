---
import "../styles/global.css";
import { faqs, site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  faqJsonLd?: boolean;
}

const {
  title = site.defaultTitle,
  description = site.defaultDescription,
  path = "/",
  faqJsonLd = false
} = Astro.props;

const canonicalPath = path === "/" ? site.basePath + "/" : `${site.basePath}/${path.replace(/^\/+/, "")}`;
const canonical = new URL(canonicalPath, site.origin).toString();
const appJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: site.name,
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Windows 10, Windows 11",
  description: site.defaultDescription,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  publisher: {
    "@type": "Organization",
    name: "sanacode"
  }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.fullName} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
    {faqJsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <a class="brand" href={`${site.basePath}/`} aria-label="Unblock by sanacode home">
          <div class="logo">U</div>
          <span>Unblock</span>
          <span class="version">v1.0</span>
        </a>

        <nav class="nav" aria-label="Primary navigation">
          <a href={`${site.basePath}/#how`}>How it works</a>
          <a href={`${site.basePath}/#features`}>Features</a>
          <a href={`${site.basePath}/#apps`}>Apps</a>
          <a href={`${site.basePath}/faq/`}>FAQ</a>
        </nav>

        <div class="status">
          <span class="status-dot"></span>
          Windows ready
        </div>
      </header>

      <slot />

      <footer class="site-footer">
        <span>{site.fullName}</span>
        <span>{site.tagline}</span>
      </footer>
    </div>
  </body>
</html>
